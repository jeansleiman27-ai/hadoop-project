<workflow-app name="grades-bigdata-workflow" xmlns="uri:oozie:workflow:0.5">

    <start to="sqoop-import"/>

    <action name="sqoop-import">
        <sqoop xmlns="uri:oozie:sqoop-action:0.4">
            <command>import --connect jdbc:mysql://host.docker.internal:3306/school --username root --password root123 --table students --target-dir /sqoop_import --m 1</command>
        </sqoop>
        <ok to="hive-analysis"/>
        <error to="fail"/>
    </action>

    <action name="hive-analysis">
        <hive xmlns="uri:oozie:hive-action:0.5">
            <script>analysis.sql</script>
        </hive>
        <ok to="end"/>
        <error to="fail"/>
    </action>

    <kill name="fail">
        <message>Grades workflow failed</message>
    </kill>

    <end name="end"/>

</workflow-app>